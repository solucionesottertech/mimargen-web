---
interface Props {
  variant?: 'primary' | 'secondary' | 'ghost';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
}

const { variant = 'primary', size = 'md', href, class: extraClass = '' } = Astro.props;

const baseStyles = 'inline-flex items-center justify-center font-semibold rounded-lg transition-all duration-150 active:scale-[0.97]';

const variants = {
  primary: 'bg-brand-600 text-white hover:bg-brand-700 shadow-md shadow-brand-600/20 hover:shadow-brand-600/30',
  secondary: 'bg-accent-600 text-white hover:bg-accent-700 shadow-md shadow-accent-600/20 hover:shadow-accent-600/30',
  ghost: 'bg-white text-slate-700 border border-slate-200 hover:bg-slate-50 hover:border-slate-300',
};

const sizes = {
  sm: 'text-sm px-4 py-2',
  md: 'text-sm px-5 py-2.5',
  lg: 'text-base px-6 py-3',
};

const classes = `${baseStyles} ${variants[variant]} ${sizes[size]} ${extraClass}`;
---

{href ? (
  <a href={href} class={classes}>
    <slot />
  </a>
) : (
  <button class={classes} type="button">
    <slot />
  </button>
)}
