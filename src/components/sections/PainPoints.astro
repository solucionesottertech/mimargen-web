---
import Card from '../ui/Card.astro';
import Section from '../ui/Section.astro';

const pains = [
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232 1.232 3.229 0 4.461l-.671.671c-1.232 1.232-3.229 1.232-4.461 0L5 10.132" /></svg>`,
    title: 'Pones precios a ojo',
    description: 'Sumas los ingredientes, le multiplicas por dos y esperas que alcance. Pero nunca sabes si realmente estás ganando o perdiendo plata.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3.375 19.5h17.25m-17.25 0a1.125 1.125 0 01-1.125-1.125M3.375 19.5h7.5c.621 0 1.125-.504 1.125-1.125m-9.75 0V5.625m0 12.75v-1.5c0-.621.504-1.125 1.125-1.125m18.375 2.625V5.625m0 12.75c0 .621-.504 1.125-1.125 1.125m1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125m0 3.75h-7.5A1.125 1.125 0 0112 18.375m9.75-12.75c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125m19.5 0v1.5c0 .621-.504 1.125-1.125 1.125M2.25 5.625v1.5c0 .621.504 1.125 1.125 1.125m0 0h17.25m-17.25 0h7.5c.621 0 1.125.504 1.125 1.125M3.375 8.25c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125m17.25-3.75h-7.5c-.621 0-1.125.504-1.125 1.125m8.625-1.125c.621 0 1.125.504 1.125 1.125v1.5c0 .621-.504 1.125-1.125 1.125m-17.25 0h7.5m-7.5 0c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125M12 10.875v-1.5m0 1.5c0 .621-.504 1.125-1.125 1.125M12 10.875c0 .621.504 1.125 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125M10.875 12c-.621 0-1.125.504-1.125 1.125M12 12c.621 0 1.125.504 1.125 1.125m-2.25 0c.621 0 1.125.504 1.125 1.125m13.5-7.5h-1.5" /></svg>`,
    title: 'Tu Excel ya no da para más',
    description: 'Tienes diez hojas de cálculo, fórmulas que se rompen solas y cada vez que cambia un precio de insumo, tienes que actualizar todo a mano. Sacar cuentas te toma horas.',
  },
  {
    icon: `<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20.25 7.5l-.625 10.632a2.25 2.25 0 01-2.247 2.118H6.622a2.25 2.25 0 01-2.247-2.118L3.75 7.5M10 11.25h4M3.375 7.5h17.25c.621 0 1.125-.504 1.125-1.125v-1.5c0-.621-.504-1.125-1.125-1.125H3.375c-.621 0-1.125.504-1.125 1.125v1.5c0 .621.504 1.125 1.125 1.125z" /></svg>`,
    title: 'No sabes cuánto stock te queda',
    description: 'Aceptas un pedido grande y recién al otro día te das cuenta de que no tienes suficiente materia prima. El stock lo llevas en la cabeza o en un cuaderno.',
  },
];
---

<Section id="producto" variant="alt">
  <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">¿Te suena familiar?</h2>
    <p class="mt-4 text-lg text-slate-600">La mayoría de los emprendedores pierden plata sin saberlo. No por falta de esfuerzo, sino por falta de visibilidad.</p>
  </div>
  <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
    {pains.map((pain) => (
      <Card variant="elevated" class="text-center hover:shadow-xl transition-shadow">
        <div class="mx-auto w-14 h-14 rounded-xl bg-brand-50 text-brand-600 flex items-center justify-center mb-5">
          {pain.icon}
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">{pain.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed">{pain.description}</p>
      </Card>
    ))}
  </div>
</Section>
