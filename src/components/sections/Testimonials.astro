---
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';

const testimonials = [
  {
    name: 'Carolina Muñoz',
    business: 'Panadería artesanal, Santiago',
    quote: 'Antes pensaba que ganaba $500 por pan. Con MiMargen descubrí que, con la merma y el tiempo de amasado, ganaba $120. Ajusté precios y ahora mi margen real es del 34%. Ojalá lo hubiera usado antes.',
    metric: 'Margen real: 34%',
  },
  {
    name: 'Diego Aravena',
    business: 'Tostador de café, Valparaíso',
    quote: 'Perdía plata en tres de mis blends y no tenía idea. MiMargen me mostró exactamente cuáles y por qué. En dos semanas ya había corregido los precios. Hoy facturo un 22% más con el mismo volumen.',
    metric: '+22% facturación',
  },
  {
    name: 'Francisca López',
    business: 'Cosmética natural, Concepción',
    quote: 'Tenía todo en Excel y era un desastre. Ahora creo la receta, pongo el precio y veo mi margen al instante. Además, las facturas electrónicas me salen directo desde ahí. Me ahorré contratar a alguien más para eso.',
    metric: 'Sin Excel',
  },
];
---

<Section id="testimonios" variant="alt">
  <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">Lo que dicen quienes ya lo usan</h2>
  </div>
  <div class="grid md:grid-cols-3 gap-6 lg:gap-8">
    {testimonials.map((t) => (
      <Card variant="elevated" class="flex flex-col">
        <div class="flex-1">
          <div class="flex items-center gap-1 mb-4">
            {Array(5).fill('⭐').map(() => <span class="text-yellow-400 text-sm">★</span>)}
          </div>
          <blockquote class="text-slate-700 text-sm leading-relaxed mb-6">"{t.quote}"</blockquote>
        </div>
        <div class="border-t border-slate-100 pt-4 flex items-center justify-between">
          <div>
            <p class="font-bold text-slate-900 text-sm">{t.name}</p>
            <p class="text-slate-500 text-xs">{t.business}</p>
          </div>
          <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-bold bg-green-100 text-green-700">{t.metric}</span>
        </div>
      </Card>
    ))}
  </div>
</Section>
