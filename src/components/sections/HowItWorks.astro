---
import Section from '../ui/Section.astro';

const steps = [
  {
    number: '01',
    title: 'Crea tu receta',
    description: 'Agrega los ingredientes o materiales que usas, con sus cantidades exactas. Puedes usar productos de tu inventario o crear insumos nuevos.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" /></svg>`,
  },
  {
    number: '02',
    title: 'Calcula el costo real',
    description: 'MiMargen suma automáticamente el costo de materiales, mano de obra, gastos fijos y la merma que generas en el proceso. Sin fórmulas, sin errores.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" /></svg>`,
  },
  {
    number: '03',
    title: 'Conoce tu margen',
    description: 'Pon tu precio de venta y ve al instante cuánto ganas realmente por cada producto. Si el margen no te cierra, ajustas y recalculas en segundos.',
    icon: `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" /></svg>`,
  },
];
---

<Section id="como-funciona" variant="default">
  <div class="text-center max-w-2xl mx-auto mb-12 sm:mb-16">
    <h2 class="text-3xl sm:text-4xl font-extrabold text-slate-900 tracking-tight">Tres pasos para conocer tu ganancia real</h2>
    <p class="mt-4 text-lg text-slate-600">Sin complicaciones. Sin hojas de cálculo. Sin contabilidad avanzada.</p>
  </div>
  <div class="grid md:grid-cols-3 gap-8 lg:gap-12">
    {steps.map((step, i) => (
      <div class="relative text-center">
        <!-- Step number -->
        <div class="mx-auto w-16 h-16 rounded-2xl bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center text-xl font-extrabold shadow-lg shadow-brand-500/25 mb-6">
          {step.number}
        </div>
        <!-- Connector line (hidden on mobile) -->
        {i < steps.length - 1 && (
          <div class="hidden md:block absolute top-8 left-2/3 w-1/3 border-t-2 border-dashed border-brand-200"></div>
        )}
        <div class="mx-auto w-10 h-10 rounded-lg bg-brand-50 text-brand-600 flex items-center justify-center mb-4">
          {step.icon}
        </div>
        <h3 class="text-lg font-bold text-slate-900 mb-2">{step.title}</h3>
        <p class="text-slate-600 text-sm leading-relaxed max-w-xs mx-auto">{step.description}</p>
      </div>
    ))}
  </div>
</Section>
